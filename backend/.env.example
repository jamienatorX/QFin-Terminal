# QFin Terminal backend environment
# Copy this file to backend/.env for local development.
# Never commit real secret values.

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Intelligent Qwen routing
# Deep financial report / analyst agent  -> Qwen3.7-Max
# Quick summary / cheaper backup         -> Qwen3.7-Plus or Qwen3.6-Flash
# Analyze image/chart/video directly     -> Qwen3.7-Plus
DASHSCOPE_MODEL_DEEP=qwen3.7-max
DASHSCOPE_MODEL_FAST=qwen3.7-plus
DASHSCOPE_MODEL_FLASH=qwen3.6-flash
DASHSCOPE_MODEL_VISION=qwen3.7-plus
DASHSCOPE_NEWS_MODEL=qwen3.7-plus
DASHSCOPE_TIMEOUT_SECONDS=45
DASHSCOPE_TOTAL_TIMEOUT_SECONDS=75

SUPABASE_URL=https://gdwfsdmheymfhwberted.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Market / financial data providers.
# QFin should use Supabase as the cache/warehouse, then fill gaps from these providers.
FMP_API_KEY=
FINNHUB_API_KEY=
NEWSAPI_KEY=
FINANCIAL_DATA_TIMEOUT_SECONDS=18

# Comma-separated allowed frontend origins.
# Wire main.py to read this instead of allow_origins=["*"] before production hardening.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://q-fin-terminal.vercel.app

APP_ENV=development
LOG_LEVEL=info
