# QFin Terminal backend environment
# Copy this file to backend/.env for local development.
# Never commit real secret values.

AI_PROVIDER_API_KEY=
AI_PROVIDER_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Quota-aware multi-model routing. Use exact dated model codes because the
# undated Qwen aliases have separate, exhausted allocations.
AI_PROVIDER_MODEL_DEEP=qwen3.7-max-2026-05-20
AI_PROVIDER_MODEL_FAST=qwen3.7-plus-2026-05-26
AI_PROVIDER_MODEL_FLASH=glm-5.1
AI_PROVIDER_MODEL_VISION=qwen-vl-plus-latest
AI_PROVIDER_NEWS_MODEL=qwen3.7-plus-2026-05-26
AI_PROVIDER_FALLBACK_MODELS=qwen3.7-max-2026-05-17,deepseek-v4-pro,glm-5.2,glm-5.1
AI_PROVIDER_FALLBACK_MODELS_VISION=qwen3-vl-plus,glm-5.2
AI_PROVIDER_QUOTA_COOLDOWN_SECONDS=21600
AI_PROVIDER_MAX_TOKENS_FAST=6000
AI_PROVIDER_MAX_TOKENS_DEEP=12000
AI_PROVIDER_MAX_TOKENS_NEWS=5000
AI_PROVIDER_MAX_TOKENS_VISION=10000
AI_PROVIDER_TIMEOUT_SECONDS_FAST=60
AI_PROVIDER_TIMEOUT_SECONDS_DEEP=150
AI_PROVIDER_TIMEOUT_SECONDS_NEWS=75
AI_PROVIDER_TIMEOUT_SECONDS_VISION=150
AI_PROVIDER_TOTAL_TIMEOUT_SECONDS_FAST=120
AI_PROVIDER_TOTAL_TIMEOUT_SECONDS_DEEP=180
AI_PROVIDER_TOTAL_TIMEOUT_SECONDS_NEWS=150
AI_PROVIDER_TOTAL_TIMEOUT_SECONDS_VISION=180
AI_PROVIDER_TIMEOUT_SECONDS=45
AI_PROVIDER_TOTAL_TIMEOUT_SECONDS=75

SUPABASE_URL=https://gdwfsdmheymfhwberted.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Market / financial data providers.
# QFin should use Supabase as the cache/warehouse, then fill gaps from these providers.
FMP_API_KEY=
FINNHUB_API_KEY=
NEWSAPI_KEY=
FINANCIAL_DATA_TIMEOUT_SECONDS=18

# Comma-separated allowed frontend origins.
# Wire main.py to read this instead of allow_origins=["*"] before production hardening.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://q-fin-terminal.vercel.app

APP_ENV=development
LOG_LEVEL=info
